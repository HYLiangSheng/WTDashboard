{
  "dialog.about.text": "<h3>War Thunder Dashboard  v{version}</h3><p>A real-time War Thunder tactical display built with PyQt6. Reads battlefield data via the in-game 8111 port API, showing a live map, unit tracking, situation report, and HUD messages on a secondary monitor or LAN device.</p><p><a href='https://github.com/HYLiangSheng/WTDashboard' style='color:#7ec8e3;'>github.com/HYLiangSheng/WTDashboard</a></p><hr style='border-color:#3a3a5c;'><p style='color:#aaaacc; font-size:10px;'>Issues, feature requests, and contributions are welcome. License: MIT</p>",
